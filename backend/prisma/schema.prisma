generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  name           String
  email          String           @unique
  password       String
  role           String           @default("user")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

// 🧾 Thông tin hộ kinh doanh
  businessName String?   // Tên hộ/cá nhân kinh doanh
  address       String?   // Địa chỉ kinh doanh
  taxCode       String?   // Mã số thuế
  bankAccount   String?   // Số tài khoản ngân hàng
  bankName      String?   // Tên ngân hàng
  phone         String?   // Số điện thoại liên hệ
  
  // Quan hệ ngược
  receipts       Receipt[]
  payments       Payment[]
  payrolls       Payroll[]
  inventoryItems InventoryItem[]
  vouchers       Voucher[]
}

model Receipt {
  id         Int       @id @default(autoincrement())
  date       DateTime
  payer      String
  reason     String?
  amount     Decimal   @db.Decimal(18, 2)
  method     String
  createdAt  DateTime  @default(now())
  createdBy  Int?
  user       User?     @relation(fields: [createdBy], references: [id])
}

model Payment {
  id         Int       @id @default(autoincrement())
  date       DateTime
  payee      String
  reason     String?
  amount     Decimal   @db.Decimal(18, 2)
  method     String
  createdAt  DateTime  @default(now())
  createdBy  Int?
  user       User?     @relation(fields: [createdBy], references: [id])
}

model Payroll {
  id         Int       @id @default(autoincrement())
  period     String
  employees  Json
  total      Decimal   @db.Decimal(18, 2)
  createdAt  DateTime  @default(now())
  createdBy  Int?
  user       User?     @relation(fields: [createdBy], references: [id])
}

model InventoryItem {
  id            Int              @id @default(autoincrement())
  code          String           @unique
  name          String
  category      String?
  unit          String?
  quantity      Int              @default(0)
  unitPriceIn   Decimal?         @db.Decimal(12, 2)
  unitPriceOut  Decimal?         @db.Decimal(12, 2)
  note          String?
  createdBy     Int
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [createdBy], references: [id])

  // Quan hệ ngược
  items         Item[]
  transactions  InventoryTxn[]
}

model InventoryTxn {
  id           Int        @id @default(autoincrement())
  itemId       Int
  type         String     // 'IN' hoặc 'OUT'
  quantity     Int
  unitPrice    Decimal?   @db.Decimal(12, 2)
  refVoucherId Int?
  createdBy    Int
  createdAt    DateTime   @default(now())

  InventoryItem InventoryItem @relation(fields: [itemId], references: [id])
}

model Voucher {
  id           Int       @id @default(autoincrement())
  type         String    // 'PNK' hoặc 'PXK'
  voucherNo    String    @unique
  date         DateTime  @default(now())
  supplier     String?
  receiver     String?
  reason       String?
  location     String?
  attachedDocs String?
  totalAmount  Decimal   @default(0) @db.Decimal(18, 2)
  businessName String?
  address      String?
  createdAt    DateTime  @default(now())
  createdBy    Int?
  user         User?     @relation(fields: [createdBy], references: [id])
  items        Item[]
}

model Item {
  id              Int             @id @default(autoincrement())
  voucherId       Int
  voucher         Voucher         @relation(fields: [voucherId], references: [id])
  name            String
  code            String?
  unit            String?
  qtyDocumented   Decimal?        @db.Decimal(18, 2)
  qtyActual       Decimal?        @db.Decimal(18, 2)
  unitPrice       Decimal?        @db.Decimal(18, 2)
  amount          Decimal?        @db.Decimal(18, 2)
  inventoryItemId Int?
  inventoryItem   InventoryItem?  @relation(fields: [inventoryItemId], references: [id])
}

model PasswordReset {
  id         Int       @id @default(autoincrement())
  email      String
  otp        String
  expiresAt  DateTime
}
