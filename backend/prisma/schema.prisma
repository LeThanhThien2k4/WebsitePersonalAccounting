generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Quan hệ ngược
  receipts       Receipt[]
  payments       Payment[]
  payrolls       Payroll[]
  stockEntries   StockEntry[]
  stockOuts      StockOut[]
  inventoryItems InventoryItem[]
  vouchers       Voucher[]
}

model Account {
  id    Int    @id @default(autoincrement())
  code  String @unique           // ví dụ: 111, 112, 511, 632
  name  String                   // tên tài khoản
  type  String                  
  // createdAt/updatedAt nếu cần:
  // createdAt DateTime @default(now())
  // updatedAt DateTime @updatedAt
}

model Receipt {
  id        Int      @id @default(autoincrement())
  date      DateTime
  payer     String
  reason    String?
  amount    Decimal  @db.Decimal(18, 2)
  method    String
  createdAt DateTime @default(now())

  createdBy Int?
  user      User? @relation(fields: [createdBy], references: [id])
}

model Payment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  payee     String
  reason    String?
  amount    Decimal  @db.Decimal(18, 2)
  method    String
  createdAt DateTime @default(now())

  createdBy Int?
  user      User? @relation(fields: [createdBy], references: [id])
}

model Payroll {
  id        Int      @id @default(autoincrement())
  period    String
  employees Json
  total     Decimal  @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  createdBy Int?
  user      User? @relation(fields: [createdBy], references: [id])
}

model InventoryItem {
  id           Int      @id @default(autoincrement())
  code         String? // Mã hàng hóa
  name         String
  category     String? // Loại hàng (thời trang, nông sản,…)
  unit         String
  quantity     Int      @default(0)
  unitPriceIn  Decimal  @default(0) @db.Decimal(18, 2)
  unitPriceOut Decimal  @default(0) @db.Decimal(18, 2)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  Int?
  user       User?        @relation(fields: [createdBy], references: [id])
  StockEntry StockEntry[]
  StockOut   StockOut[]
  items      Item[]
}

model StockEntry {
  id        Int           @id @default(autoincrement())
  date      DateTime      @default(now())
  quantity  Int
  unitPrice Decimal       @db.Decimal(18, 2)
  total     Decimal       @db.Decimal(18, 2)
  note      String?
  item      InventoryItem @relation(fields: [itemId], references: [id])
  itemId    Int

  createdBy Int?
  user      User? @relation(fields: [createdBy], references: [id])
}

model StockOut {
  id       Int           @id @default(autoincrement())
  date     DateTime      @default(now())
  quantity Int
  note     String?
  item     InventoryItem @relation(fields: [itemId], references: [id])
  itemId   Int

  createdBy Int?
  user      User? @relation(fields: [createdBy], references: [id])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
}

model Voucher {
  id           Int      @id @default(autoincrement())
  type         String // 'PNK' hoặc 'PXK'
  voucherNo    String   @unique
  date         DateTime @default(now())
  supplier     String? // Người giao hàng (PNK)
  receiver     String? // Người nhận hàng (PXK)
  reason       String? // Lý do xuất / nhập
  location     String? // Địa điểm nhập / xuất kho
  attachedDocs String? // Số chứng từ gốc kèm theo
  totalAmount  Decimal  @default(0) @db.Decimal(18, 2)
  businessName String?
  address      String?
  createdAt    DateTime @default(now())

  items     Item[]
  createdBy Int?
  user      User?  @relation(fields: [createdBy], references: [id])
}

model Item {
  id            Int      @id @default(autoincrement())
  voucherId     Int
  voucher       Voucher  @relation(fields: [voucherId], references: [id])
  name          String
  code          String?
  unit          String?
  qtyDocumented Decimal? @db.Decimal(18, 2)
  qtyActual     Decimal? @db.Decimal(18, 2)
  unitPrice     Decimal? @db.Decimal(18, 2)
  amount        Decimal? @db.Decimal(18, 2)

  // Liên kết với hàng hóa trong kho
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId Int?
}
