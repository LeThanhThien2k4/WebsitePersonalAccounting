<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>S5-HKD</title>
  <style>
    body { font-family: "Times New Roman", serif; font-size: 13px; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    th, td { border: 1px solid #000; padding: 4px 6px; }
    .no-border td { border: none !important; }
    .bold { font-weight: bold; }
    .center { text-align: center; }
    .left { text-align: left; }
    .right { text-align: right; }
    .title { font-size: 18px; font-weight: bold; text-align: center; margin-top: 10px; }
    .subtitle { text-align: center; margin-bottom: 10px; }
    .footer td { border: none; text-align: center; padding-top: 40px; }
  </style>
</head>
<body>

<table class="no-border">
  <tr>
    <td class="left bold">
      HỘ, CÁ NHÂN KINH DOANH: <%= businessName || "" %>
    </td>
    <td class="right">
      Mẫu số S5-HKD<br/>
      <span style="font-size: 11px">(Ban hành kèm theo Thông tư 88/2021/TT-BTC)</span>
    </td>
  </tr>
  <tr>
    <td class="left bold">Địa chỉ: <%= address || "" %></td>
    <td></td>
  </tr>
</table>

<div class="title">
  SỔ THEO DÕI TÌNH HÌNH THANH TOÁN TIỀN LƯƠNG VÀ CÁC KHOẢN NỘP THEO LƯƠNG CỦA NGƯỜI LAO ĐỘNG
</div>
<div class="subtitle">
  Năm: <%= year %>
</div>

<table>
  <tr class="bold center">
    <td rowspan="2">Ngày, tháng ghi sổ<br/>(A)</td>
    <td rowspan="2">Số hiệu<br/>(B)</td>
    <td rowspan="2">Diễn giải<br/>(D)</td>
    <td colspan="3">Tiền lương và thu nhập của người lao động</td>
    <td colspan="3">BHXH</td>
    <td colspan="3">BHYT</td>
    <td colspan="3">BHTN</td>
  </tr>
  <tr class="bold center">
    <td>Số phải trả<br/>(1)</td>
    <td>Số đã trả<br/>(2)</td>
    <td>Số còn phải trả<br/>(3)</td>
    <td>Số phải trả<br/>(4)</td>
    <td>Số đã trả<br/>(5)</td>
    <td>Số còn phải trả<br/>(6)</td>
    <td>Số phải trả<br/>(7)</td>
    <td>Số đã trả<br/>(8)</td>
    <td>Số còn phải trả<br/>(9)</td>
    <td>Số phải trả<br/>(10)</td>
    <td>Số đã trả<br/>(11)</td>
    <td>Số còn phải trả<br/>(12)</td>
  </tr>
  <tr class="bold center">
    <td>A</td><td>B</td><td>D</td>
    <td>1</td><td>2</td><td>3</td>
    <td>4</td><td>5</td><td>6</td>
    <td>7</td><td>8</td><td>9</td>
    <td>10</td><td>11</td><td>12</td>
  </tr>

  <% rows.forEach(function(r) { %>
    <tr>
      <td class="center"><%= r.dateVN %></td>
      <td class="center"><%= r.docNo %></td>
      <td class="left"><%= r.desc || "" %></td>

      <td class="right"><%= r.wageMust.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.wagePaid.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.wageRemain.toLocaleString("vi-VN") %></td>

      <td class="right"><%= r.bhxhMust.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhxhPaid.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhxhRemain.toLocaleString("vi-VN") %></td>

      <td class="right"><%= r.bhytMust.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhytPaid.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhytRemain.toLocaleString("vi-VN") %></td>

      <td class="right"><%= r.bhtnMust.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhtnPaid.toLocaleString("vi-VN") %></td>
      <td class="right"><%= r.bhtnRemain.toLocaleString("vi-VN") %></td>
    </tr>
  <% }) %>

  <tr class="bold">
    <td colspan="3" class="center">Cộng số phát sinh trong kỳ</td>

    <td class="right"><%= totals.wageMust.toLocaleString("vi-VN") %></td>
    <td class="right"><%= totals.wagePaid.toLocaleString("vi-VN") %></td>
    <td class="right"><%= totals.wageRemain.toLocaleString("vi-VN") %></td>

    <td class="right"><%= totals.bhxhMust.toLocaleString("vi-VN") %></td>
    <td class="right"><%= (0).toLocaleString("vi-VN") %></td>
    <td class="right"><%= totals.bhxhRemain.toLocaleString("vi-VN") %></td>

    <td class="right"><%= totals.bhytMust.toLocaleString("vi-VN") %></td>
    <td class="right"><%= (0).toLocaleString("vi-VN") %></td>
    <td class="right"><%= totals.bhytRemain.toLocaleString("vi-VN") %></td>

    <td class="right"><%= totals.bhtnMust.toLocaleString("vi-VN") %></td>
    <td class="right"><%= (0).toLocaleString("vi-VN") %></td>
    <td class="right"><%= totals.bhtnRemain.toLocaleString("vi-VN") %></td>
  </tr>
</table>

<table class="footer">
  <tr>
    <td>NGƯỜI LẬP BIỂU<br/><br/><br/>(Ký, họ tên)</td>
    <td>NGƯỜI ĐẠI DIỆN HỘ KD<br/><br/><br/>(Ký, họ tên, đóng dấu)</td>
  </tr>
</table>

</body>
</html>
