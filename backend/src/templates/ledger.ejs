<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title><%= title %></title>
  <style>
    body { font-family: 'Times New Roman', serif; font-size: 13px; color: #000; margin: 30px; }
    table { border-collapse: collapse; width: 100%; margin-top: 10px; }
    th, td { border: 1px solid #000; padding: 4px; }
    th { background: #f3f3f3; text-align: center; }
    h2 { text-align: center; font-size: 16px; margin: 10px 0; }
    .sign { margin-top: 40px; display: flex; justify-content: space-between; text-align: center; }
  </style>
</head>
<body>
  <div>
    <b>HỘ KINH DOANH:</b> <%= businessName %><br />
    <b>Địa chỉ:</b> <%= address %>
  </div>
  <h2><%= title %></h2>

  <table>
    <thead>
      <tr>
        <th>STT</th><th>Ngày</th><th>Loại</th><th>Nội dung</th><th>Số tiền (VNĐ)</th>
      </tr>
    </thead>
    <tbody>
      <% if (rows.length === 0) { %>
        <tr><td colspan="5" style="text-align:center">Không có dữ liệu</td></tr>
      <% } else { rows.forEach((r, i) => { %>
        <tr>
          <td style="text-align:center"><%= i+1 %></td>
          <td style="text-align:center"><%= new Date(r.date).toLocaleDateString("vi-VN") %></td>
          <td style="text-align:center"><%= r.type %></td>
          <td><%= r.reason %></td>
          <td style="text-align:right"><%= r.signedAmount.toLocaleString("vi-VN") %></td>
        </tr>
      <% }) } %>
    </tbody>
  </table>

  <div style="text-align:right;margin-top:15px">
    🔹 Tổng thu: <b><%= totalIn.toLocaleString("vi-VN") %> đ</b><br/>
    🔸 Tổng chi: <b><%= totalOut.toLocaleString("vi-VN") %> đ</b><br/>
    💰 Tồn cuối kỳ: <b><%= balance.toLocaleString("vi-VN") %> đ</b>
  </div>

  <div class="sign">
    <div>NGƯỜI LẬP SỔ<br/><i>(Ký, họ tên)</i></div>
    <div>CHỦ HỘ<br/><i>(Ký, họ tên)</i></div>
    <div>KẾ TOÁN TRƯỞNG<br/><i>(Ký, họ tên)</i></div>
  </div>
</body>
</html>
