<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <style>
    body {
      font-family: "Times New Roman", serif;
      font-size: 13px;
      color: black;
      line-height: 1.6;
      padding: 30px;
      width: 794px;
      margin: 0 auto;
      background: white;
    }
    .tt-table { border-collapse: collapse; width: 100%; font-size: 13px; }
    .tt-table th, .tt-table td { border: 1px solid #000; padding: 6px; }
    .tt-th { font-weight: 600; text-align: center; vertical-align: middle; }
    .tt-sub td { border-left: 1px solid #000; border-right: 1px solid #000; text-align: center; }
    .text-center { text-align: center; }
    .text-right { text-align: right; }
    .italic { font-style: italic; }
    .bold { font-weight: bold; }
    .sign-grid { display: grid; grid-template-columns: repeat(4, 1fr); text-align: center; gap: 20px; margin-top: 24px; }
    .sign-title { font-weight: bold; }
    .sign-note { font-style: italic; font-size: 12px; }
  </style>
</head>

<body>
  <!-- Header -->
  <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
    <div>
      <div><b>HỘ, CÁ NHÂN KINH DOANH:</b> <%= businessName || "........................................" %></div>
      <div><b>Địa chỉ:</b> <%= address || "...................................................." %></div>
    </div>
    <div class="text-right">
      <div><b>Mẫu số <%= isEntry ? "03" : "04" %> - VT</b></div>
      <div style="font-size:11px; line-height:14px;">
        (Ban hành kèm theo Thông tư số 88/2021/TT-BTC ngày 11 tháng 10 năm 2021 của Bộ Tài chính)
      </div>
    </div>
  </div>

  <!-- Tiêu đề -->
  <div class="text-center" style="margin-bottom:12px;">
    <div class="bold" style="font-size:16px;">
      <%= isEntry ? "PHIẾU NHẬP KHO" : "PHIẾU XUẤT KHO" %>
    </div>
    <div>Ngày ...... tháng ...... năm ......</div>
    <div>Số: <%= voucherNo || "........................" %></div>
  </div>

  <!-- Thông tin -->
  <div style="margin-bottom:8px;">
    <% if (isEntry) { %>
      <div>- Họ và tên người giao hàng: <%= supplier || ".............................................................." %></div>
      <div>- Theo .......... số .......... ngày ..... tháng ..... năm ..... của .....................</div>
      <div>Địa điểm nhập kho: <%= location || ".............................................................." %></div>
    <% } else { %>
      <div>- Họ và tên người nhận hàng: <%= receiver || ".............................................................." %></div>
      <div>- Lý do xuất kho: <%= reason || ".............................................................." %></div>
      <div>Địa điểm xuất kho: <%= location || ".............................................................." %></div>
    <% } %>
  </div>

  <!-- Bảng TT88 -->
  <table class="tt-table">
    <thead>
      <tr>
        <th class="tt-th" rowspan="2" style="width:50px;">STT</th>
        <th class="tt-th" rowspan="2">
          Tên, nhãn hiệu, quy cách, phẩm chất vật liệu, dụng cụ, sản phẩm, hàng hóa
        </th>
        <th class="tt-th" rowspan="2" style="width:80px;">Mã số</th>
        <th class="tt-th" rowspan="2" style="width:90px;">Đơn vị tính</th>
        <th class="tt-th" colspan="2" style="width:180px;">Số lượng</th>
        <th class="tt-th" rowspan="2" style="width:110px;">Đơn giá</th>
        <th class="tt-th" rowspan="2" style="width:120px;">Thành tiền</th>
      </tr>
      <tr>
        <th class="tt-th">Theo chứng từ</th>
        <th class="tt-th"><%= isEntry ? "Thực nhập" : "Thực xuất" %></th>
      </tr>
      <tr class="tt-sub">
        <td class="tt-th">A</td>
        <td class="tt-th">B</td>
        <td class="tt-th">C</td>
        <td class="tt-th">D</td>
        <td class="tt-th">1</td>
        <td class="tt-th">2</td>
        <td class="tt-th">3</td>
        <td class="tt-th">4</td>
      </tr>
    </thead>
    <tbody>
      <% items.forEach((r, i) => { %>
        <tr>
          <td class="text-center"><%= i + 1 %></td>
          <td><%= r.name || "" %></td>
          <td class="text-center"><%= r.code || "" %></td>
          <td class="text-center"><%= r.unit || "" %></td>
          <td class="text-right"><%= r.qtyDocumented || "" %></td>
          <td class="text-right"><%= r.qtyActual || "" %></td>
          <td class="text-right"><%= Number(r.unitPrice || 0).toLocaleString("vi-VN") %></td>
          <td class="text-right"><%= Number(r.amount || 0).toLocaleString("vi-VN") %></td>
        </tr>
      <% }) %>
      <tr>
        <td colspan="7" class="text-right bold">Cộng</td>
        <td class="text-right bold"><%= Number(total || 0).toLocaleString("vi-VN") %></td>
      </tr>
    </tbody>
  </table>

  <!-- Dòng sau bảng -->
  <div style="margin-top:8px;">
    <div>- Tổng số tiền (viết bằng chữ): <%= amountText.replace("Tổng số tiền (viết bằng chữ): ", "") %></div>
    <div>- Số chứng từ gốc kèm theo: <%= attachedDocs || ".............................................................." %></div>
  </div>

  <!-- Ký tên -->
  <div style="margin-top:24px; text-align:right;">Ngày ..... tháng ..... năm ......</div>

  <div class="sign-grid">
    <% 
      const roles = isEntry
        ? ["NGƯỜI GIAO HÀNG", "THỦ KHO", "NGƯỜI LẬP BIỂU", "NGƯỜI ĐẠI DIỆN HỘ KINH DOANH/ CÁ NHÂN KINH DOANH"]
        : ["NGƯỜI NHẬN HÀNG", "THỦ KHO", "NGƯỜI LẬP BIỂU", "NGƯỜI ĐẠI DIỆN HỘ KINH DOANH/ CÁ NHÂN KINH DOANH"];
      roles.forEach((t) => { %>
      <div>
        <div class="sign-title"><%= t %></div>
        <div class="sign-note">(Ký, họ tên)</div>
        <div style="height:60px;"></div>
      </div>
    <% }) %>
  </div>
</body>
</html>
