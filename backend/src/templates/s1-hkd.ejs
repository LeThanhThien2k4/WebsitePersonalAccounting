<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>S1-HKD</title>

  <style>
    body {
      font-family: "Times New Roman", serif;
      font-size: 14px;
      line-height: 1.4;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    th, td {
      border: 1px solid #000;
      padding: 4px 6px;
      text-align: center;
    }

    .no-border td {
      border: none !important;
      padding: 2px;
    }

    .bold { font-weight: bold; }
    .center { text-align: center; }
    .left   { text-align: left; }
    .right  { text-align: right; }

    .title {
      font-size: 20px;
      font-weight: bold;
      text-align: center;
      margin: 10px 0 5px;
      text-transform: uppercase;
    }

    .subtitle {
      font-size: 15px;
      text-align: center;
      margin-bottom: 15px;
    }

    .footer {
      width: 100%;
      margin-top: 25px;
    }

    .footer td {
      border: none;
      padding-top: 40px;
      text-align: center;
    }

  </style>
</head>

<body>

  <!-- Header HKD -->
  <table class="no-border">
    <tr>
      <td class="left bold">HỘ, CÁ NHÂN KINH DOANH: <%= businessName %></td>
      <td class="right">Mẫu số S1-HKD<br/>
        <span style="font-size: 12px">(Ban hành kèm theo Thông tư 88/2021/TT-BTC)</span>
      </td>
    </tr>
    <tr>
      <td class="left bold">Địa chỉ: <%= address %></td>
      <td></td>
    </tr>
  </table>

  <!-- Title -->
  <div class="title">SỔ CHI TIẾT DOANH THU BÁN HÀNG HOÁ, DỊCH VỤ</div>
  <div class="subtitle">
    Tên địa điểm kinh doanh: <%= businessName %> <br/>
    Năm: <%= year %>
  </div>

  <!-- TABLE HEADER -->
  <table>
    <tr class="bold">
      <td rowspan="2" style="width: 90px">Ngày ghi sổ<br/>(A)</td>

      <!-- Chứng từ -->
      <td colspan="2">Chứng từ</td>

      <td rowspan="2" style="width: 130px">Diễn giải<br/>(D)</td>

      <!-- Nhóm ngành nghề -->
      <td colspan="4">Doanh thu bán hàng hoá, dịch vụ theo nhóm ngành nghề</td>

      <td rowspan="2">Ghi chú<br/>(12)</td>
    </tr>

    <tr class="bold">
      <td style="width: 60px">Số hiệu<br/>(B)</td>
      <td style="width: 80px">Ngày tháng<br/>(C)</td>

      <td>(1)<br/>Phân phối</td>
      <td>(2)<br/>Dịch vụ</td>
      <td>(3)<br/>Xây dựng<br/>vận tải</td>
      <td>(4)<br/>Hoạt động<br/>khác</td>
    </tr>

    <tr class="bold center">
      <td>A</td><td>B</td><td>C</td><td>D</td>
      <td>1</td><td>2</td><td>3</td><td>4</td>
      <td>12</td>
    </tr>

    <% rows.forEach(r => { %>
      <tr>
        <td><%= new Date(r.date).toLocaleDateString("vi-VN") %></td>
        <td><%= r.no %></td>
        <td><%= new Date(r.docDate).toLocaleDateString("vi-VN") %></td>

        <td class="left"><%= r.desc %></td>

        <!-- Chỉ cột (1) có dữ liệu, còn lại 0 -->
        <td class="right"><%= r.col1.toLocaleString("vi-VN") %></td>
        <td>0</td>
        <td>0</td>
        <td>0</td>

        <td></td>
      </tr>
    <% }) %>

    <!-- TOTAL -->
    <tr class="bold">
      <td colspan="4" class="center">Tổng cộng</td>

      <td class="right"><%= totalCol1.toLocaleString("vi-VN") %></td>
      <td>0</td>
      <td>0</td>
      <td>0</td>

      <td></td>
    </tr>
  </table>

  <!-- FOOTER -->
  <table class="footer">
    <tr>
      <td>NGƯỜI LẬP BIỂU<br/><br/><br/>(Ký, họ tên)</td>
      <td>NGƯỜI ĐẠI DIỆN HỘ KD<br/><br/><br/>(Ký, họ tên, đóng dấu)</td>
    </tr>
  </table>

</body>
</html>
