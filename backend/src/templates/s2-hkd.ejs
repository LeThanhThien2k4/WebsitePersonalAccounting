<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <title>Sổ chi tiết vật liệu – S2-HKD</title>

  <style>
    body {
      font-family: "Times New Roman", serif;
      font-size: 14px;
      line-height: 1.4;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    th, td {
      border: 1px solid #000;
      padding: 3px 5px;
      text-align: center;
    }

    .no-border td { border: none !important; }
    .left  { text-align: left; }
    .right { text-align: right; }
    .bold  { font-weight: bold; }
  </style>
</head>

<body>

  <!-- HEADER -->
  <table class="no-border">
    <tr>
      <td class="left">
        <strong>HỘ, CÁ NHÂN KINH DOANH:</strong> <%= businessName %><br/>
        <strong>Địa chỉ:</strong> <%= address %>
      </td>
      <td class="right">
        <strong>Mẫu số S2-HKD</strong><br/>
        <i>(Ban hành theo Thông tư 88/2021/TT-BTC)</i>
      </td>
    </tr>
  </table>

  <h2 style="text-align:center;margin-bottom:5px;">
    SỔ CHI TIẾT VẬT LIỆU, DỤNG CỤ, SẢN PHẨM, HÀNG HÓA<br/>
    <span style="font-size:15px;">Tên vật liệu, dụng cụ, sản phẩm, hàng hóa: <%= itemName %></span><br/>
    <span style="font-size:15px;">Năm: <%= year %></span>
  </h2>

  <!-- TABLE -->
  <table>
    <thead>
      <tr>
        <th rowspan="2" style="width:95px;">Chứng từ<br/>A-B</th>
        <th rowspan="2" style="width:120px;">Diễn giải (D)</th>
        <th rowspan="2" style="width:60px;">ĐVT</th>
        <th rowspan="2" style="width:70px;">Đơn giá (1)</th>

        <th colspan="2">Nhập</th>
        <th colspan="2">Xuất</th>
        <th colspan="2">Tồn</th>

        <th rowspan="2" style="width:70px;">Ghi chú</th>
      </tr>

      <tr>
        <th>SL (2)</th>
        <th>Thành tiền (3)</th>
        <th>SL (4)</th>
        <th>Thành tiền (5)</th>
        <th>SL (6)</th>
        <th>Thành tiền (7)</th>
      </tr>
    </thead>

    <tbody>

      <!-- OPENING BALANCE -->
      <tr>
        <td colspan="8" class="left bold">Số dư đầu kỳ</td>

        <td class="right bold">
          <%= openingQty < 0
                ? "-" + Math.abs(openingQty).toLocaleString("vi-VN")
                : openingQty.toLocaleString("vi-VN")
          %>
        </td>

        <td class="right bold">
          <%= openingCost < 0
                ? "-" + Math.abs(openingCost).toLocaleString("vi-VN")
                : openingCost.toLocaleString("vi-VN")
          %>
        </td>

        <td></td>
      </tr>

      <% rows.forEach(r => { %>
      <tr>
        <td>
          <%= r.docNo %><br/>
          <%= r.dateVN %>
        </td>

        <td class="left"><%= r.desc %></td>

        <td><%= r.unit %></td>

        <td class="right"><%= r.price.toLocaleString("vi-VN") %></td>

        <!-- NHẬP: tiền âm -->
        <td class="right">
          <%= r.qtyIn ? r.qtyIn.toLocaleString("vi-VN") : "" %>
        </td>

        <td class="right">
          <%= r.totalIn ? "-" + r.totalIn.toLocaleString("vi-VN") : "" %>
        </td>

        <!-- XUẤT: SL âm, tiền dương -->
        <td class="right">
          <%= r.qtyOut ? "-" + Math.abs(r.qtyOut).toLocaleString("vi-VN") : "" %>
        </td>

        <td class="right">
          <%= r.totalOut ? "+" + r.totalOut.toLocaleString("vi-VN") : "" %>
        </td>

        <!-- TỒN -->
        <td class="right">
          <%= r.balanceQty < 0
                ? "-" + Math.abs(r.balanceQty).toLocaleString("vi-VN")
                : r.balanceQty.toLocaleString("vi-VN")
          %>
        </td>

        <td class="right">
          <%= r.balanceCost < 0
                ? "-" + Math.abs(r.balanceCost).toLocaleString("vi-VN")
                : r.balanceCost.toLocaleString("vi-VN")
          %>
        </td>

        <td></td>
      </tr>
      <% }) %>

      <!-- TỔNG NHẬP – TỔNG XUẤT + TỒN -->
      <tr class="bold">
        <td colspan="4" class="left">Tổng nhập – Tổng xuất – Tồn</td>

        <td class="right"><%= totalInQty.toLocaleString("vi-VN") %></td>
        <td class="right">-<%= totalInCost.toLocaleString("vi-VN") %></td>

        <td class="right">-<%= totalOutQty.toLocaleString("vi-VN") %></td>
        <td class="right">+<%= totalOutCost.toLocaleString("vi-VN") %></td>

        <td class="right">
          <%= closingQty < 0
                ? "-" + Math.abs(closingQty).toLocaleString("vi-VN")
                : closingQty.toLocaleString("vi-VN")
          %>
        </td>

        <td class="right">
          <%= closingCost < 0
                ? "-" + Math.abs(closingCost).toLocaleString("vi-VN")
                : closingCost.toLocaleString("vi-VN")
          %>
        </td>

        <td></td>
      </tr>

      <!-- SỐ DƯ CUỐI KỲ = Xuất – Nhập + Tồn -->
      <tr class="bold">
        <td colspan="8" class="left">Số dư cuối kỳ (Lãi/Lỗ)</td>

        <td></td>

        <td class="right">
          <%= closingBalance < 0
                ? "-" + Math.abs(closingBalance).toLocaleString("vi-VN")
                : closingBalance.toLocaleString("vi-VN")
          %>
        </td>

        <td></td>
      </tr>

    </tbody>
  </table>

  <br/><br/><br/>

  <!-- SIGNATURE -->
  <table class="no-border">
    <tr>
      <td class="center" style="width:50%;">
        <strong>NGƯỜI LẬP BIỂU</strong><br/>
        <i>(Ký, ghi rõ họ tên)</i>
      </td>

      <td class="center" style="width:50%;">
        <strong>NGƯỜI ĐẠI DIỆN HỘ KD</strong><br/>
        <i>(Ký, họ tên, đóng dấu)</i>
      </td>
    </tr>
  </table>

</body>
</html>
