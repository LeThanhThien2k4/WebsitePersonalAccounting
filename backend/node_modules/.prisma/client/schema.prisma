generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int             @id @default(autoincrement())
  name           String
  email          String          @unique
  password       String
  role           String          @default("user")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  address        String?
  bankAccount    String?
  bankName       String?
  businessName   String?
  phone          String?
  taxCode        String?
  employees      Employee[]
  inventoryItems InventoryItem[]
  payments       Payment[]
  payrollPayouts PayrollPayout[]
  payrollPeriods PayrollPeriod[]
  receipts       Receipt[]
  vouchers       Voucher[]
}

model Receipt {
  id        Int      @id @default(autoincrement())
  date      DateTime
  payer     String
  reason    String?
  amount    Decimal  @db.Decimal(18, 2)
  method    String
  createdAt DateTime @default(now())
  createdBy Int?
  user      User?    @relation(fields: [createdBy], references: [id])
}

model Payment {
  id        Int      @id @default(autoincrement())
  date      DateTime
  payee     String
  reason    String?
  amount    Decimal  @db.Decimal(18, 2)
  method    String
  createdAt DateTime @default(now())
  createdBy Int?
  user      User?    @relation(fields: [createdBy], references: [id])
}

model InventoryItem {
  id        Int      @id @default(autoincrement())
  name      String
  unit      String?
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy    Int // user ID
  category     String?
  code         String // bỏ @unique để cho phép trùng giữa các user
  note         String?
  unitPriceIn  Decimal? @db.Decimal(12, 2)
  unitPriceOut Decimal? @db.Decimal(12, 2)

  user         User           @relation(fields: [createdBy], references: [id])
  transactions InventoryTxn[]
  items        Item[]

  // UNIQUE theo tổ hợp (code + createdBy)
  @@unique([code, createdBy])
}

model InventoryTxn {
  id            Int           @id @default(autoincrement())
  itemId        Int
  type          String
  quantity      Int
  unitPrice     Decimal?      @db.Decimal(12, 2)
  refVoucherId  Int?
  createdBy     Int
  createdAt     DateTime      @default(now())
  InventoryItem InventoryItem @relation(fields: [itemId], references: [id])
}

model Voucher {
  id           Int      @id @default(autoincrement())
  type         String
  voucherNo    String // bỏ @unique ở đây
  date         DateTime @default(now())
  supplier     String?
  receiver     String?
  reason       String?
  location     String?
  attachedDocs String?
  totalAmount  Decimal  @default(0) @db.Decimal(18, 2)
  businessName String?
  address      String?
  createdAt    DateTime @default(now())
  createdBy    Int?
  items        Item[]
  user         User?    @relation(fields: [createdBy], references: [id])

  // Mỗi user có thể có PNK2025...-001 riêng
  @@unique([voucherNo, createdBy])
}

model Item {
  id              Int            @id @default(autoincrement())
  voucherId       Int
  name            String
  code            String?
  unit            String?
  qtyDocumented   Decimal?       @db.Decimal(18, 2)
  qtyActual       Decimal?       @db.Decimal(18, 2)
  unitPrice       Decimal?       @db.Decimal(18, 2)
  amount          Decimal?       @db.Decimal(18, 2)
  inventoryItemId Int?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  voucher         Voucher        @relation(fields: [voucherId], references: [id])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  otp       String
  expiresAt DateTime
}

model Employee {
  id           Int             @id @default(autoincrement())
  code         String?
  fullName     String
  position     String?
  joinDate     DateTime?
  leaveDate    DateTime?
  isActive     Boolean         @default(true)
  baseSalary   Decimal         @db.Decimal(18, 2)
  bankAccount  String?
  bankName     String?
  createdBy    Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  creator      User?           @relation(fields: [createdBy], references: [id])
  payrollItems PayrollItem[]
  payouts      PayrollPayout[]

  @@unique([code, createdBy])
  @@index([isActive])
  @@index([fullName])
}

model PayrollPeriod {
  id        Int             @id @default(autoincrement())
  month     Int
  year      Int
  status    PayrollStatus   @default(DRAFT)
  lockedAt  DateTime?
  note      String?
  ownerId   Int?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     PayrollItem[]
  payouts   PayrollPayout[]
  owner     User?           @relation(fields: [ownerId], references: [id])
  rates     PayrollRate[]

  @@unique([ownerId, month, year])
  @@index([status])
}

model PayrollRate {
  id            Int            @id @default(autoincrement())
  periodId      Int?
  effectiveFrom DateTime
  bhxhEmp       Decimal        @db.Decimal(5, 2)
  bhxhEr        Decimal        @db.Decimal(5, 2)
  bhytEmp       Decimal        @db.Decimal(5, 2)
  bhytEr        Decimal        @db.Decimal(5, 2)
  bhtnEmp       Decimal        @db.Decimal(5, 2)
  bhtnEr        Decimal        @db.Decimal(5, 2)
  unionEmp      Decimal        @db.Decimal(5, 2)
  unionEr       Decimal        @db.Decimal(5, 2)
  salaryCeiling Decimal?       @db.Decimal(18, 2)
  salaryFloor   Decimal?       @db.Decimal(18, 2)
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  period        PayrollPeriod? @relation(fields: [periodId], references: [id])

  @@index([effectiveFrom, active])
}

model PayrollItem {
  id                Int            @id @default(autoincrement())
  periodId          Int
  employeeId        Int
  salaryBase        Decimal        @db.Decimal(18, 2)
  daysWorked        Decimal        @db.Decimal(6, 2)
  otHours           Decimal        @db.Decimal(8, 2)
  allowances        Decimal        @default(0) @db.Decimal(18, 2)
  bonus             Decimal        @default(0) @db.Decimal(18, 2)
  otherIncome       Decimal        @default(0) @db.Decimal(18, 2)
  deductUnpaid      Decimal        @default(0) @db.Decimal(18, 2)
  advance           Decimal        @default(0) @db.Decimal(18, 2)
  bhxhEmp           Decimal        @default(0) @db.Decimal(18, 2)
  bhytEmp           Decimal        @default(0) @db.Decimal(18, 2)
  bhtnEmp           Decimal        @default(0) @db.Decimal(18, 2)
  unionEmp          Decimal        @default(0) @db.Decimal(18, 2)
  gross             Decimal        @db.Decimal(18, 2)
  netPay            Decimal        @db.Decimal(18, 2)
  note              String?
  payoutId          Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  benefitOther      Decimal?       @default(0) @db.Decimal(18, 2)
  taxTncn           Decimal?       @default(0) @db.Decimal(18, 2)
  grossBeforeDeduct Decimal?       @default(0) @db.Decimal(18, 2)
  employee          Employee       @relation(fields: [employeeId], references: [id])
  payout            PayrollPayout? @relation(fields: [payoutId], references: [id])
  period            PayrollPeriod  @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, employeeId])
  @@index([payoutId])
}

model PayrollPayout {
  id         Int           @id @default(autoincrement())
  periodId   Int
  employeeId Int?
  method     PayoutMethod  @default(CASH)
  amount     Decimal       @db.Decimal(18, 2)
  payDate    DateTime      @default(now())
  paymentRef String?
  createdBy  Int?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  items      PayrollItem[]
  creator    User?         @relation(fields: [createdBy], references: [id])
  employee   Employee?     @relation(fields: [employeeId], references: [id])
  period     PayrollPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([payDate])
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  LOCKED
  PAID
}

enum PayoutMethod {
  CASH
  TRANSFER
}
